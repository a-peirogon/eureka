# ── Application ──────────────────────────────────────────────────
APP_NAME=ICFES Eureka API
ENVIRONMENT=development
DEBUG=true

# ── Security — CHANGE IN PRODUCTION ──────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-change-me-in-production-use-openssl

# ── Database ──────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://icfes:icfes_secret@localhost:5432/icfes_db

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI (required for AI features) ────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── Storage (MinIO local / S3 / R2) ──────────────────────────────
STORAGE_BACKEND=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=icfes-files
STORAGE_PUBLIC_URL=http://localhost:9000/icfes-files

# ── CORS ──────────────────────────────────────────────────────────
# Comma-separated origins
# ALLOWED_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ── Email (optional) ──────────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASSWORD=your-password

# ── Observability (optional) ──────────────────────────────────────
# SENTRY_DSN=https://your-dsn@sentry.io/project
